server <- function(input, output, session) {
mod_lstf_server(
id = "lstf01",
satellite = "goes19",
product = "ABI-L2-LSTF",
interval_ms = 600000,
n_files = 1,
initial_lng = -75,
initial_lat = 5,
initial_zoom = 3
)
observeEvent(input[["lstf01-btn_go_home"]], {
showNotification("Botón ← Launcher presionado", type = "message")
}, ignoreInit = TRUE)
}
