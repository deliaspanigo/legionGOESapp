# ============================================================
# SERVER
# ============================================================
server <- function(input, output, session) {
downloaded_files <- reactiveVal(character(0))
glm_data <- reactiveVal(data.frame())
glm_running <- reactiveVal(FALSE)
glm_status <- reactiveVal("Detenido. Presione iniciar.")
glm_last_check <- reactiveVal("-")
glm_last_file <- reactiveVal("-")
# ------------------------------------------------------------
# MAPA INICIAL
# ------------------------------------------------------------
output$map <- renderLeaflet({
leaflet(options = leafletOptions(zoomControl = TRUE)) %>%
setView(lng = -64.1888, lat = -31.4201, zoom = 4) %>%
addProviderTiles(providers$CartoDB.DarkMatter)
})
# ------------------------------------------------------------
# CAMBIO DE MAPA BASE
# ------------------------------------------------------------
observeEvent(input$base_map, {
proxy <- leafletProxy("map") %>%
clearTiles()
if (input$base_map == "osm") {
proxy %>% addProviderTiles(providers$OpenStreetMap)
}
if (input$base_map == "carto_light") {
proxy %>% addProviderTiles(providers$CartoDB.Positron)
}
if (input$base_map == "carto_dark") {
proxy %>% addProviderTiles(providers$CartoDB.DarkMatter)
}
if (input$base_map == "esri_sat") {
proxy %>% addProviderTiles(providers$Esri.WorldImagery)
}
if (input$base_map == "esri_topo") {
proxy %>% addProviderTiles(providers$Esri.WorldTopoMap)
}
if (input$base_map == "esri_terrain") {
proxy %>% addProviderTiles(providers$Esri.WorldTerrain)
}
}, ignoreInit = TRUE)
# ------------------------------------------------------------
# CAPAS SUPERIORES
# ------------------------------------------------------------
observe({
layers <- input$overlay_layers
proxy <- leafletProxy("map") %>%
clearGroup("limites_internacionales") %>%
clearGroup("limites_provinciales") %>%
clearGroup("capitales") %>%
clearGroup("ciudades")
if (is.null(layers)) {
return()
}
if ("limites_internacionales" %in% layers) {
proxy %>%
addPolygons(
data = world_borders,
group = "limites_internacionales",
fillOpacity = 0,
color = "black",
weight = 1,
opacity = 0.9,
label = ~nombre_pais
)
}
if ("limites_provinciales" %in% layers) {
proxy %>%
addPolylines(
data = admin1_lines,
group = "limites_provinciales",
color = "gray30",
weight = 0.8,
opacity = 0.85,
label = ~nombre_admin1
)
}
if ("capitales" %in% layers) {
proxy %>%
addCircleMarkers(
data = capitales,
lng = ~long,
lat = ~lat,
group = "capitales",
radius = 4,
color = "red",
fillColor = "red",
fillOpacity = 0.9,
stroke = TRUE,
weight = 1,
label = ~paste0(name, " - ", country.etc),
popup = ~paste0(
"<b>", name, "</b><br>",
"País: ", country.etc, "<br>",
"Población: ", pop
)
)
}
if ("ciudades" %in% layers) {
proxy %>%
addCircleMarkers(
data = ciudades,
lng = ~long,
lat = ~lat,
group = "ciudades",
radius = 3,
color = "blue",
fillColor = "blue",
fillOpacity = 0.7,
stroke = TRUE,
weight = 1,
label = ~paste0(name, " - ", country.etc),
popup = ~paste0(
"<b>", name, "</b><br>",
"País: ", country.etc, "<br>",
"Población: ", pop
)
)
}
})
# ------------------------------------------------------------
# BOTONES GLM
# ------------------------------------------------------------
observeEvent(input$start_glm, {
glm_running(TRUE)
glm_status("GLM iniciado. Buscando archivos...")
})
observeEvent(input$pause_glm, {
glm_running(FALSE)
glm_status("Pausado")
})
observeEvent(input$clear_glm, {
glm_data(data.frame())
downloaded_files(character(0))
glm_status("Acumulado borrado")
glm_last_file("-")
leafletProxy("map") %>%
clearGroup("Rayos GLM")
})
# ------------------------------------------------------------
# DESCARGA GLM CADA 20 SEGUNDOS
# ------------------------------------------------------------
observe({
invalidateLater(20000, session)
if (!isTRUE(glm_running())) {
return()
}
glm_status("Buscando imágenes GLM...")
glm_last_check(format(Sys.time(), "%Y-%m-%d %H:%M:%S"))
latest_urls <- tryCatch({
get_latest_glm_files(
satellite = "goes19",
product = "GLM-L2-LCFA",
n_files = 3
)
}, error = function(e) {
character(0)
})
if (length(latest_urls) == 0) {
glm_status("Sin archivos encontrados")
return()
}
old_files <- downloaded_files()
new_urls <- latest_urls[!basename(latest_urls) %in% old_files]
if (length(new_urls) == 0) {
glm_status("Sin archivos nuevos")
return()
}
all_new_data <- list()
for (url in new_urls) {
glm_status(paste("Descargando:", basename(url)))
glm_last_file(basename(url))
df <- tryCatch({
read_glm_flashes(url)
}, error = function(e) {
data.frame()
})
if (nrow(df) > 0) {
all_new_data[[length(all_new_data) + 1]] <- df
}
}
downloaded_files(unique(c(old_files, basename(new_urls))))
if (length(all_new_data) > 0) {
new_df <- bind_rows(all_new_data)
current_df <- glm_data()
if (nrow(current_df) == 0) {
total_df <- new_df
} else {
total_df <- bind_rows(current_df, new_df)
}
glm_data(total_df)
glm_status("GLM actualizado")
} else {
glm_status("Archivos descargados, sin flashes")
}
})
# ------------------------------------------------------------
# ACTUALIZAR RAYOS EN EL MAPA
# ------------------------------------------------------------
observe({
df <- glm_data()
proxy <- leafletProxy("map") %>%
clearGroup("Rayos GLM")
if (nrow(df) == 0) {
return()
}
proxy %>%
addCircleMarkers(
data = df,
lng = ~lon,
lat = ~lat,
group = "Rayos GLM",
radius = 4,
stroke = TRUE,
weight = 1,
color = "yellow",
fillColor = "red",
fillOpacity = 0.8,
opacity = 1,
popup = ~paste0(
"<b>GLM Flash</b><br>",
"Lat: ", round(lat, 3), "<br>",
"Lon: ", round(lon, 3), "<br>",
"Energía: ", signif(energy, 3), "<br>",
"Archivo: ", file, "<br>",
"Descargado: ", downloaded_at
)
)
})
# ------------------------------------------------------------
# SALIDAS DEL MENÚ GLM
# ------------------------------------------------------------
output$glm_status <- renderText({
glm_status()
})
output$glm_last_check <- renderText({
glm_last_check()
})
output$glm_last_file <- renderText({
glm_last_file()
})
output$glm_files_count <- renderText({
length(downloaded_files())
})
output$glm_flash_count <- renderText({
nrow(glm_data())
})
}
shinyApp(ui, server)
