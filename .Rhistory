lats <- c()
lons <- c()
colors <- c()
labels <- c()
sizes <- c()
# Agregar satélites geoestacionarios (fijos)
for(i in 1:nrow(geoestacionarios)) {
lats <- c(lats, 0)
lons <- c(lons, geoestacionarios$longitud[i])
colors <- c(colors, geoestacionarios$color[i])
labels <- c(labels, paste0(geoestacionarios$nombre[i], " (GEO)"))
sizes <- c(sizes, 8)
}
# Agregar satélites en órbita baja (en movimiento)
for(i in 1:nrow(orbita_baja)) {
lon_key <- paste0("lon_", i)
lat_key <- paste0("lat_", i)
lats <- c(lats, sat_positions[[lat_key]])
lons <- c(lons, sat_positions[[lon_key]])
colors <- c(colors, orbita_baja$color[i])
labels <- c(labels, paste0(orbita_baja$nombre[i], " (LEO)"))
sizes <- c(sizes, 6)
}
list(lat = lats, lon = lons, color = colors, label = labels, size = sizes)
})
# Actualizar panel de texto
output$sat_positions <- renderText({
texto <- "=== GEOESTACIONARIOS (FIJOS) ===\n"
for(i in 1:nrow(geoestacionarios)) {
texto <- paste0(texto, geoestacionarios$nombre[i], ": ",
abs(geoestacionarios$longitud[i]), "°",
ifelse(geoestacionarios$longitud[i] < 0, "O", "E"), " sobre ecuador\n")
}
texto <- paste0(texto, "\n=== ÓRBITA BAJA ===\n")
for(i in 1:nrow(orbita_baja)) {
lon_val <- sat_positions[[paste0("lon_", i)]]
lat_val <- sat_positions[[paste0("lat_", i)]]
texto <- paste0(texto, orbita_baja$nombre[i], ": ",
sprintf("%.1f", abs(lat_val)), ifelse(lat_val >= 0, "N", "S"), " / ",
sprintf("%.1f", abs(lon_val)), ifelse(lon_val >= 0, "E", "O"), "\n")
}
texto
})
# Textura del globo (usando URL confiable)
texture_url <- "https://threejs.org/examples/textures/planets/earth_atmos_2048.jpg"
# Renderizar el globo
output$globo <- renderGlobe({
data <- build_globe_data()
globejs(
img = texture_url,
lat = data$lat,
long = data$lon,
color = data$color,
pointsize = data$size,
label = data$label,
atmosphere = TRUE,
bg = "black",
bodycolor = "#111111",
lightcolor = "#ffffff",
emissive = "#222222",
rotationlat = -0.3,
rotationlong = -0.5,
fov = 40
)
})
# Observador para animación continua
observe({
autoInvalidate()
if(running()) {
actualizar_orbita()
counter(counter() + 1)
# Actualizar el globo
data <- build_globe_data()
# Re-renderizar con nuevas posiciones
output$globo <- renderGlobe({
globejs(
img = texture_url,
lat = data$lat,
long = data$lon,
color = data$color,
pointsize = data$size,
label = data$label,
atmosphere = TRUE,
bg = "black",
bodycolor = "#111111",
lightcolor = "#ffffff",
emissive = "#222222",
rotationlat = -0.3,
rotationlong = -0.5,
fov = 40
)
})
}
})
# Controles
observeEvent(input$play, {
running(TRUE)
})
observeEvent(input$stop, {
running(FALSE)
})
observeEvent(input$reset_view, {
# Resetear vista recargando el globo
data <- build_globe_data()
output$globo <- renderGlobe({
globejs(
img = texture_url,
lat = data$lat,
long = data$lon,
color = data$color,
pointsize = data$size,
label = data$label,
atmosphere = TRUE,
bg = "black",
bodycolor = "#111111",
lightcolor = "#ffffff",
emissive = "#222222",
rotationlat = -0.3,
rotationlong = -0.5,
fov = 40
)
})
})
}
shinyApp(ui, server)
runApp('R/app16.R')
